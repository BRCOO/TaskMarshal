{
  "name": "taskmarshal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex-led task dispatch and review for local CLI coding-agent workers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BRCOO/TaskMarshal.git"
  },
  "bugs": {
    "url": "https://github.com/BRCOO/TaskMarshal/issues"
  },
  "homepage": "https://github.com/BRCOO/TaskMarshal#readme",
  "keywords": [
    "codex",
    "mcp",
    "reasonix",
    "deepseek",
    "coding-agent",
    "task-orchestration",
    "cli-agent"
  ],
  "bin": {
    "taskmarshalctl": "./taskmarshalctl.js",
    "reasonixctl": "./reasonixctl.js",
    "reasonix-mcp": "./mcp-server.js",
    "taskmarshal-mcp": "./mcp-server.js"
  },
  "scripts": {
    "check": "node --check taskmarshalctl.js && node --check reasonixctl.js && node --check lib/acp-client.js && node --check lib/context-adapter.js && node --check lib/worker-output-contract.js && node --check mcp-server.js && node --check scripts/token-saving-benchmark.js && node --check scripts/quality-benchmark.js && node --check scripts/codex-ab-benchmark.js && node --check scripts/skillopt-gate.js",
    "doctor": "node taskmarshalctl.js doctor",
    "eval": "node scripts/taskmarshal-eval.js",
    "eval:codex-ab": "node scripts/codex-ab-benchmark.js",
    "eval:quality": "node scripts/quality-benchmark.js",
    "eval:skillopt": "node scripts/skillopt-gate.js",
    "eval:tokens": "node scripts/token-saving-benchmark.js",
    "mcp": "node mcp-server.js",
    "mcp:smoke": "node scripts/mcp-smoke.js",
    "smoke": "node taskmarshalctl.js smoke"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@colbymchenry/codegraph": "^0.9.8"
  }
}
